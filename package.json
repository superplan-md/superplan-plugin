{
  "name": "superplan",
  "version": "0.1.0",
  "description": "Superplan CLI",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "output",
    "scripts/install.sh",
    "scripts/install.ps1",
    "scripts/install.cmd",
    "README.md",
    "package.json"
  ],
  "bin": {
    "superplan": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc && node ./scripts/copy-skills.js && node ./scripts/generate-outputs.js",
    "desktop:build": "pnpm --dir apps/desktop build",
    "desktop:dev": "pnpm --dir apps/desktop dev",
    "overlay:bundle": "node ./scripts/overlay-release.js build",
    "overlay:package": "node ./scripts/overlay-release.js package",
    "overlay:release": "node ./scripts/overlay-release.js build-package",
    "overlay:release:github": "node ./scripts/overlay-release-dispatch.js",
    "start": "node ./dist/cli/main.js",
    "test": "npm run build && node --test test/*.test.cjs",
    "visibility:examples": "node ./scripts/visibility-scenarios.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
